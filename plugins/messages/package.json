{
  "name": "@devframes/plugin-messages",
  "type": "module",
  "version": "0.6.1",
  "description": "Devframe plugin — the hub message feed as a portable panel: browse, filter, and dismiss `ctx.messages` entries from any hub host.",
  "author": "Anthony Fu <anthonyfu117@hotmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/devframes/devframe#readme",
  "repository": {
    "directory": "plugins/messages",
    "type": "git",
    "url": "git+https://github.com/devframes/devframe.git"
  },
  "bugs": "https://github.com/devframes/devframe/issues",
  "keywords": [
    "devframe",
    "devframe-plugin",
    "devtools",
    "messages",
    "notifications"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./client": "./dist/client/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./constants": "./dist/constants.mjs",
    "./node": "./dist/node/index.mjs",
    "./rpc": "./dist/rpc/index.mjs",
    "./types": "./dist/types.mjs",
    "./vite": "./dist/vite.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "devframe-messages": "./bin.mjs"
  },
  "files": [
    "bin.mjs",
    "dist"
  ],
  "scripts": {
    "build": "tsdown && vite build --config src/client/vite.config.ts && vite build --config src/spa/vite.config.ts",
    "dev": "vite --config src/spa/vite.config.ts --host 0.0.0.0",
    "watch": "tsdown --watch",
    "cli:build": "node bin.mjs build --out-dir dist/static",
    "prepack": "pnpm build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@devframes/hub": "workspace:*",
    "devframe": "workspace:*",
    "vite": "^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "nostics": "catalog:deps"
  },
  "devDependencies": {
    "@antfu/design": "catalog:frontend",
    "@devframes/hub": "workspace:*",
    "@iconify-json/ph": "catalog:frontend",
    "@storybook/addon-docs": "catalog:storybook",
    "@storybook/vue3-vite": "catalog:storybook",
    "@types/node": "catalog:types",
    "@vitejs/plugin-vue": "catalog:build",
    "@vueuse/core": "catalog:frontend",
    "colorjs.io": "catalog:frontend",
    "devframe": "workspace:*",
    "get-port-please": "catalog:deps",
    "h3": "catalog:deps",
    "storybook": "catalog:storybook",
    "tsdown": "catalog:build",
    "unocss": "catalog:frontend",
    "vite": "catalog:build",
    "vite-plugin-css-injected-by-js": "catalog:frontend",
    "vitest": "catalog:testing",
    "vue": "catalog:frontend",
    "ws": "catalog:deps"
  }
}
