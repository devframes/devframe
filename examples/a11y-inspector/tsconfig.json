{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vite/client"],
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedDeclarations": false
  },
  "include": ["src", "tests", "demo", "bin.mjs"]
}
